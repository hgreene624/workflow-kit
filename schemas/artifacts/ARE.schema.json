{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow-kit/schemas/artifacts/ARE.schema.json",
  "title": "ARE frontmatter (Agent Report)",
  "description": "Required YAML frontmatter for an ARE (Agent Report) document. category MUST be \"Report\" or \"Review\". Extra frontmatter keys are allowed.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "date created",
    "tags",
    "category",
    "status"
  ],
  "properties": {
    "date created": {
      "type": "string",
      "format": "date",
      "description": "Creation date (YYYY-MM-DD)."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Relevant tags."
    },
    "category": {
      "enum": [
        "Report",
        "Review"
      ],
      "description": "Must be \"Report\" (agent report under /reports/) or \"Review\" (review artifact under /reviews/)."
    },
    "status": {
      "type": "string",
      "description": "Lifecycle status of the document."
    }
  }
}
