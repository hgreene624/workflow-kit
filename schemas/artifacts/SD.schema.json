{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow-kit/schemas/artifacts/SD.schema.json",
  "title": "SD frontmatter (System Definition)",
  "description": "Required YAML frontmatter for a SD (System Definition) document. category MUST be \"System Definition\". Extra frontmatter keys are allowed.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "date created",
    "tags",
    "category",
    "status",
    "version",
    "date modified"
  ],
  "properties": {
    "date created": {
      "type": "string",
      "format": "date",
      "description": "Creation date (YYYY-MM-DD)."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Relevant tags."
    },
    "category": {
      "const": "System Definition",
      "description": "Must be exactly \"System Definition\" for a SD document."
    },
    "status": {
      "type": "string",
      "description": "Lifecycle status of the document."
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Document version (constitutional docs increment in place)."
    },
    "date modified": {
      "type": "string",
      "format": "date",
      "description": "Last-modified date (YYYY-MM-DD)."
    }
  }
}
