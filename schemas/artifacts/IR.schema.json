{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow-kit/schemas/artifacts/IR.schema.json",
  "title": "IR frontmatter (Incident Report)",
  "description": "Required YAML frontmatter for a IR (Incident Report) document. category MUST be \"Report\". Extra frontmatter keys are allowed.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "date created",
    "tags",
    "category",
    "status",
    "severity"
  ],
  "properties": {
    "date created": {
      "type": "string",
      "format": "date",
      "description": "Creation date (YYYY-MM-DD)."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Relevant tags."
    },
    "category": {
      "const": "Report",
      "description": "Must be exactly \"Report\" for a IR document."
    },
    "status": {
      "type": "string",
      "description": "Lifecycle status of the document."
    },
    "severity": {
      "type": "string",
      "description": "Incident severity (e.g. P1/P2/P3)."
    },
    "resolved": {
      "type": "boolean",
      "description": "Whether the issue is resolved."
    },
    "affects": {
      "type": "string",
      "description": "What the report affects."
    }
  }
}
