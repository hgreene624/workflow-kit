{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow-kit/schemas/artifacts/DD.schema.json",
  "title": "DD frontmatter (Design Discussion)",
  "description": "Required YAML frontmatter for a DD (Design Discussion) document. category MUST be \"Plan\". Extra frontmatter keys are allowed.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "date created",
    "tags",
    "category",
    "status",
    "source"
  ],
  "properties": {
    "date created": {
      "type": "string",
      "format": "date",
      "description": "Creation date (YYYY-MM-DD)."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Relevant tags."
    },
    "category": {
      "const": "Plan",
      "description": "Must be exactly \"Plan\" for a DD document."
    },
    "status": {
      "type": "string",
      "description": "Lifecycle status of the document."
    },
    "source": {
      "type": "string",
      "description": "Wikilink to the source spec/request this derives from."
    }
  }
}
