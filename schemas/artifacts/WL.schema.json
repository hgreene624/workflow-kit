{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow-kit/schemas/artifacts/WL.schema.json",
  "title": "WL frontmatter (Work Log)",
  "description": "Required YAML frontmatter for a WL (Work Log) document. category MUST be \"Reference\". Extra frontmatter keys are allowed.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "date created",
    "tags",
    "category"
  ],
  "properties": {
    "date created": {
      "type": "string",
      "format": "date",
      "description": "Creation date (YYYY-MM-DD)."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Relevant tags."
    },
    "category": {
      "const": "Reference",
      "description": "Must be exactly \"Reference\" for a WL document."
    }
  }
}
