{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow-kit/schemas/artifacts/PIC.schema.json",
  "title": "PIC frontmatter (Pickup)",
  "description": "Required YAML frontmatter for a PIC (Pickup) document. category MUST be \"Report\". Extra frontmatter keys are allowed.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "date created",
    "tags",
    "category",
    "status",
    "project"
  ],
  "properties": {
    "date created": {
      "type": "string",
      "format": "date",
      "description": "Creation date (YYYY-MM-DD)."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Relevant tags."
    },
    "category": {
      "const": "Report",
      "description": "Must be exactly \"Report\" for a PIC document."
    },
    "status": {
      "type": "string",
      "description": "Lifecycle status of the document."
    },
    "project": {
      "type": "string",
      "description": "The project this document belongs to."
    },
    "pickup_date": {
      "type": "string",
      "format": "date",
      "description": "Next workday this pickup is scheduled for (YYYY-MM-DD)."
    }
  }
}
