{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow-kit/schemas/artifacts/RM.schema.json",
  "title": "RM frontmatter (Roadmap (legacy))",
  "description": "Required YAML frontmatter for a RM (Roadmap (legacy)) document. category MUST be \"Plan\". Extra frontmatter keys are allowed.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "date created",
    "tags",
    "category"
  ],
  "properties": {
    "date created": {
      "type": "string",
      "format": "date",
      "description": "Creation date (YYYY-MM-DD)."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Relevant tags."
    },
    "category": {
      "const": "Plan",
      "description": "Must be exactly \"Plan\" for a RM document."
    }
  }
}
